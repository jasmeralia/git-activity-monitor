# Required
GITHUB_TOKEN=ghp_your_token_here
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/ID/TOKEN

# Optional — set after first run to enable pinned message editing
DISCORD_PINNED_MESSAGE_ID=

# Optional — second webhook for GitHub release and GHCR version notifications
# (public repos only; stars/watches/PRs/issues remain on the main channel)
DISCORD_RELEASES_WEBHOOK_URL=
# Set after first run to enable editing the releases channel pinned catalog
DISCORD_RELEASES_PINNED_MESSAGE_ID=

# Optional — second webhook for Dependabot security alerts; falls back to
# DISCORD_WEBHOOK_URL if unset
DISCORD_SECURITY_WEBHOOK_URL=

# Comma-separated GitHub users/orgs — monitors all non-fork, non-archived repos automatically
OWNERS=

# Comma-separated "owner/repo" pairs — explicit repos (at least one of OWNERS or REPOSITORIES required)
REPOSITORIES=owner/repo-a,owner/repo-b

# Comma-separated "owner/package" pairs (for GHCR monitoring)
GHCR_PACKAGES=owner/my-app

# Which event types to monitor (comma-separated)
# Valid values: stars, watches, prs, issues, releases, ghcr, alerts
ENABLED_EVENTS=stars,watches,prs,issues,releases,ghcr,alerts

# Polling interval in seconds (default: 300 = 5 minutes)
POLL_INTERVAL_SECONDS=300

# Path to state file (default: /data/state.json; change for local testing)
STATE_FILE_PATH=/data/state.json

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
